  <Source dwd:design-time-name="82a841fd-98ed-4c55-bbc8-8daba11813b7">
    <DataSourceViewID>Do An OLAP</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="adb5778e-df5e-481e-96b5-bcf07970b9d7">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;       
CREATE DYNAMIC SET CURRENTCUBE.[OfficeProducts]
 AS DESCENDANTS(
    [Dim Product].[Hierarchy].&amp;[Office Supplies],
    [Dim Product].[Hierarchy].[Product Name],
    LEAVES
);  
CREATE MEMBER CURRENTCUBE.[Measures].[Power BI Cau 6]
 AS CASE 
WHEN [Dim Customer].[Customer Name].CurrentMember.Level.Name = "(All)" 
OR [Dim Customer].[Customer Name].CurrentMember.Level.Name = "Segment" 
THEN NULL
ELSE
RANK(
[Dim Customer].[Customer Name].CurrentMember,
ORDER(
NONEMPTY( 
[Dim Customer].[Customer Name].CurrentMember.Siblings,
[Measures].[Sales]
),
[Measures].[Sales],
BDESC
)    )
END, 
FORMAT_STRING = "Standard", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Power BI Cau 8 Sales Qualified]
 AS SUM(
EXISTING [Dim Location].[State].[State].Members, 
IIF( [Measures].[Sales] &gt;= 2000 AND [Measures].[Sales] &lt;= 100000, [Measures].[Sales], NULL 
)
), 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Power BI Cau 8 State Rank In Region]
 AS CASE
        WHEN [Dim Location].[Hierarchy].CurrentMember.Level.Name = "(All)"
          OR [Dim Location].[Hierarchy].CurrentMember.Level.Name = "Country"
          OR [Dim Location].[Hierarchy].CurrentMember.Level.Name = "Region"
        THEN NULL
        
        ELSE
        RANK(
            [Dim Location].[Hierarchy].CurrentMember,
            ORDER(
                NONEMPTY(
                    [Dim Location].[Hierarchy].CurrentMember.Siblings,
                    [Measures].[Power BI Cau 8 Sales Qualified] 
                ),
                [Measures].[Power BI Cau 8 Sales Qualified],
                BDESC
            )
        )
    END, 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Power BI Cau 10 SoLuongTieuBang]
 AS COUNT( EXISTING [Dim Location].[Hierarchy].[State]), 
FORMAT_STRING = "Standard", 
VISIBLE = 1;       
CREATE DYNAMIC SET CURRENTCUBE.[TOP 5 Doanh So Cao Nhat]
 AS TOPCOUNT(
    [OfficeProducts],
    5,
    ([Measures].[Sales], [Dim Location].[Hierarchy].[Region].&amp;[West])
), DISPLAY_FOLDER = 'sets';    
CREATE DYNAMIC SET CURRENTCUBE.[Tieu Bang Co Loi Nhuan Duong Tru Tieu Bang California]
 AS FILTER(
        EXCEPT(
            [Dim Location].[State].Children,
            {[Dim Location].[State].&amp;[California]}
        ),
        ([Measures].[Profit], [Dim Time].[Year].&amp;[2017]) &gt; 0
    );     
CREATE DYNAMIC SET CURRENTCUBE.[Vung Co Doanh So Lon Hon 100000]
 AS FILTER(
    [Dim Location].[Hierarchy].[Region],
    ([Measures].[Sales], [Dim Time].[Year].&amp;[2016]) &gt; 100000
);     
CREATE MEMBER CURRENTCUBE.[Measures].[Ty Suat Loi Nhuan]
 AS IIF([Measures].[Sales] = 0, NULL, [Measures].[Profit] / [Measures].[Sales]), 
FORMAT_STRING = "Percent", 
VISIBLE = 1;     
CREATE MEMBER CURRENTCUBE.[Measures].[2014]
 AS ( [Measures].[Sales], [Dim Time].[Hierarchy].[Year].&amp;[2014], [Dim Location].[Region].&amp;[South] ), 
VISIBLE = 1;     
CREATE MEMBER CURRENTCUBE.[Measures].[2015]
 AS ( [Measures].[Sales], [Dim Time].[Hierarchy].[Year].&amp;[2015], [Dim Location].[Region].&amp;[South]  ), 
VISIBLE = 1;     
CREATE MEMBER CURRENTCUBE.[Measures].[2016]
 AS ( [Measures].[Sales], [Dim Time].[Hierarchy].[Year].&amp;[2016], [Dim Location].[Region].&amp;[South] ), 
VISIBLE = 1;     
CREATE MEMBER CURRENTCUBE.[Measures].[2017]
 AS ( [Measures].[Sales], [Dim Time].[Hierarchy].[Year].&amp;[2017], [Dim Location].[Region].&amp;[South] ), 
VISIBLE = 1; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>